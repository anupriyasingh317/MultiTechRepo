<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="oracle.manageddataaccess.client"
      type="OracleInternal.Common.ODPMSectionHandler, Oracle.ManagedDataAccess, Version=4.122.19.1, Culture=neutral, PublicKeyToken=89b483f429c47342" />
  </configSections>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.1" />
  </startup>

  <connectionStrings>
    <!--
    Oracle Connection String
    Update the following parameters:
    - Data Source: Your Oracle database TNS name or connection descriptor
    - User Id: Database user with access to payment processing schema
    - Password: Database user password
    - Pooling: Connection pooling enabled for better performance
    -->
    <add name="OracleConnection"
         connectionString="Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL)));User Id=PAYMENT_USER;Password=your_password;Pooling=true;Min Pool Size=5;Max Pool Size=100;Connection Timeout=60;"
         providerName="Oracle.ManagedDataAccess.Client" />

    <!--
    Alternative connection string formats:

    1. Using TNS Name:
    connectionString="Data Source=ORCL;User Id=PAYMENT_USER;Password=your_password;Pooling=true;"

    2. Using Easy Connect:
    connectionString="Data Source=localhost:1521/ORCL;User Id=PAYMENT_USER;Password=your_password;Pooling=true;"

    3. Production with enhanced security:
    connectionString="Data Source=prod_tns;User Id=PAYMENT_USER;Password=encrypted_password;Pooling=true;Min Pool Size=10;Max Pool Size=200;Connection Timeout=30;Validate Connection=true;Statement Cache Size=50;"
    -->
  </connectionStrings>

  <appSettings>
    <!-- Application Settings -->
    <add key="ApplicationName" value="Payment Processing System" />
    <add key="Version" value="1.0.0" />
    <add key="Environment" value="Development" />

    <!-- Payment Processing Settings -->
    <add key="DefaultCurrency" value="USD" />
    <add key="MaxPaymentAmount" value="1000000" />
    <add key="MinPaymentAmount" value="0.01" />

    <!-- Database Settings -->
    <add key="CommandTimeout" value="120" />
    <add key="EnableDatabaseLogging" value="true" />

    <!-- Integration Settings -->
    <add key="GatewayFilePath" value="C:\PaymentFiles\Gateway\" />
    <add key="ReconciliationReportPath" value="C:\PaymentFiles\Reports\" />

    <!-- Python Integration Settings -->
    <add key="PythonScriptPath" value="C:\Users\2000108444\Documents\MultiTechRepo\Python\" />
    <add key="DataMigrationEnabled" value="true" />
  </appSettings>

  <oracle.manageddataaccess.client>
    <version number="*">
      <dataSources>
        <dataSource alias="ORCL" descriptor="(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL)))" />
      </dataSources>

      <settings>
        <!-- Oracle Managed Data Access Settings -->
        <setting name="TraceLevel" value="0" />
        <!-- 0 = Off, 1 = Public, 2 = Public + Internal, 4 = Full -->

        <setting name="TraceOption" value="0" />
        <!-- 0 = Off, 1 = On -->

        <setting name="StatementCachePurge" value="false" />
        <setting name="StatementCacheSize" value="50" />

        <!-- Connection Pool Settings -->
        <setting name="PoolMaxSize" value="100" />
        <setting name="PoolMinSize" value="5" />
        <setting name="PoolConnectionTimeout" value="60" />
        <setting name="PoolIncrement" value="5" />

        <!-- Performance Settings -->
        <setting name="FetchSize" value="131072" />
        <!-- 128KB default fetch size -->

        <setting name="BindByName" value="true" />
        <!-- Bind parameters by name instead of position -->
      </settings>
    </version>
  </oracle.manageddataaccess.client>

  <system.diagnostics>
    <trace autoflush="true" indentsize="4">
      <listeners>
        <add name="OracleTraceListener"
             type="System.Diagnostics.TextWriterTraceListener"
             initializeData="C:\Logs\PaymentApp_Oracle.log" />
      </listeners>
    </trace>
  </system.diagnostics>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Oracle.ManagedDataAccess" publicKeyToken="89b483f429c47342" culture="neutral" />
        <bindingRedirect oldVersion="4.121.0.0 - 4.65535.65535.65535" newVersion="4.122.19.1" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>

</configuration>
